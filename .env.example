# Copie ce fichier en .env et remplis les valeurs
# Ne JAMAIS commit le .env sur GitHub

# JWT — génère une chaîne aléatoire longue (ex: openssl rand -hex 32)
JWT_SECRET=CHANGE_MOI_AVEC_UNE_LONGUE_CHAINE_ALEATOIRE

# PayPal — récupérés sur developer.paypal.com
PAYPAL_CLIENT_ID=TON_CLIENT_ID_PAYPAL
PAYPAL_CLIENT_SECRET=TON_CLIENT_SECRET_PAYPAL
PAYPAL_PLAN_ID=P-TON_PLAN_ID
PAYPAL_WEBHOOK_ID=TON_WEBHOOK_ID

# Environnement (sandbox pour tester, live pour la prod)
PAYPAL_ENV=sandbox

# Port (Railway le définit automatiquement)
PORT=3000

# URL de ton site (pour les redirections)
SITE_URL=https://urgot-guide-production.up.railway.app
